{
    "version": 1,
    "cutoffDate": "2013-01-01 00:00:00",
    "environment": "development",
    "noOfWorkers": 2,
    "newCutoffDate": "",
    "loadDirectories": {
        "copy": [
            {
                "name": "archive",
                "source": "/notebooks/load",
                "destination": "/dags/process_wwi_archive/{archive_folder}/load"
            },
            {
                "name": "modules",
                "source": "/notebooks/modules",
                "destination": "/dags/process_wwi_archive/{archive_folder}/load/modules"
            },
            {
                "name": "resources",
                "source": "/resources",
                "destination": "/dags/process_wwi_archive/resources"
            }
        ],
        "create": [
            {
                "destination": "/dags/process_wwi_archive/{archive_folder}/load/outputs"
            }
        ],
        "replaceFiles": [
            {
                "name": "config",
                "source": "/dags/process_wwi_archive/{archive_folder}/load/load_wwi_{environment}.json",
                "destination": "/dags/process_wwi_archive/{archive_folder}/load/load_wwi.json"
            }
        ],
        "archivePath": "",
        "configPath": "",
        "modulesPath": ""
    },
    "warehouseDirectories": {
        "copy": [
            {
                "name": "archive",
                "source": "/notebooks/warehouse",
                "destination": "/dags/process_wwi_archive/{archive_folder}/warehouse"
            },
            {
                "name": "modules",
                "source": "/notebooks/modules",
                "destination": "/dags/process_wwi_archive/{archive_folder}/warehouse/modules"
            },
            {
                "name": "resources",
                "source": "/resources",
                "destination": "/dags/process_wwi_archive/resources"
            }
        ],
        "create": [
            {
                "destination": "/dags/process_wwi_archive/{archive_folder}/warehouse/outputs"
            }
        ],
        "replaceFiles": [
            {
                "name": "config",
                "source": "/dags/process_wwi_archive/{archive_folder}/warehouse/warehouse_wwi_{environment}.json",
                "destination": "/dags/process_wwi_archive/{archive_folder}/warehouse/warehouse_wwi.json"
            }
        ],
        "archivePath": "",
        "configPath": "",
        "modulesPath": ""
    },
    "copyFilesType": {
        "type": "github",
        "tokenPath": "/dags/credentials/github_token.txt",
        "owner": "ragsragsrags",
        "repo": "WideWorldImportersELT_ApacheBeam",
        "branch": "dev"
    },
    "releaseGithubTag": "",
    "raiseErrorWhenNewVersionFound": false,
    "dagFile": "process_wwi_v3.py",
    "dagConfigFile": "process_wwi_v3.json"
}